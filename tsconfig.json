{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2024",
    "moduleResolution": "NodeNext",
    "removeComments": false,
    "alwaysStrict": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@builder/*": ["./builder/source/*"],
      "@reporoot/*": ["./*"]
    }
  }
}